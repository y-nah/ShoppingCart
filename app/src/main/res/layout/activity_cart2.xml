<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF5F7">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Cart 🛒"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#C2185B"
        android:layout_gravity="center"
        android:padding="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Order Summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Subtotal:" android:textSize="14sp" android:textColor="#555555"/>
            <TextView android:id="@+id/tvSubtotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="P0.00" android:textSize="14sp" android:textColor="#555555"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Shipping:" android:textSize="14sp" android:textColor="#555555"/>
            <TextView android:id="@+id/tvShipping"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="P50.00" android:textSize="14sp" android:textColor="#555555"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tax (12%):" android:textSize="14sp" android:textColor="#555555"/>
            <TextView android:id="@+id/tvTax"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="P0.00" android:textSize="14sp" android:textColor="#555555"/>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FCE4EC"
            android:layout_marginBottom="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Total:" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#C2185B"/>
            <TextView android:id="@+id/tvGrandTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="P0.00" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#C2185B"/>
        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Keep Browsing"
            android:backgroundTint="#F06292"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnCheckout"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Checkout"
            android:backgroundTint="#C2185B"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"/>

    </LinearLayout>

</LinearLayout>
